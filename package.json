{
  "name": "specdrivr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run killall && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "kill:3000": "lsof -ti:3000 | xargs kill -9 || true",
    "kill:3001": "lsof -ti:3001 | xargs kill -9 || true",
    "killall": "pkill -f \"next dev\" || true && npm run kill:3000 && npm run kill:3001",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "psql $DATABASE_URL < db/seed-comprehensive.sql",
    "seed:demo": "node scripts/seed-demo-drizzle.js",
    "setup": "npm run db:push && npm run db:seed",
    "fkillall": "fkill -f \"npm run dev\"",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@uiw/react-md-editor": "^4.0.11",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.30",
    "next-remove-imports": "^1.0.12",
    "postgres": "^3.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rehype-sanitize": "^6.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.21.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
