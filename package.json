{
  "name": "specdrivr_current",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run killall && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "kill:3000": "lsof -ti:3000 | xargs kill -9 || true",
    "kill:3001": "lsof -ti:3001 | xargs kill -9 || true",
    "killall": "pkill -f \"next dev\" || true && npm run kill:3000 && npm run kill:3001",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:demo": "node scripts/seed-demo-drizzle.js",
    "test:seed": "node tests/seed-test-data.js",
    "test:e2e": "npm run test:seed && npx playwright test",
    "test:unit": "jest",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.18.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "next": "^14.2.35",
    "pg": "^8.19.0",
    "postgres": "^3.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
